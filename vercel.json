{
    "version": 2,
    "installCommand": "pnpm install",
    "buildCommand": "pnpm turbo run build",
    "builds": [
        {
            "src": "apps/api/index.ts",
            "use": "@vercel/node"
        },
        {
            "src": "apps/web/dist/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "apps/api/index.ts"
        },
        {
            "src": "/(.*)",
            "dest": "apps/web/dist/$1"
        }
    ]
}